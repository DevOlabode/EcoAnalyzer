<% if(success && success.length > 0){ %>
<div class="flash-container" id="flashContainer">
    <% for(let msg of success){ %>
    <div class="flash-message success">
        <i class="fas fa-check-circle flash-icon"></i>
        <span><%= msg %></span>
        <button onclick="this.parentElement.remove()" style="margin-left:auto; background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:1rem; padding:0 0 0 8px;">&times;</button>
    </div>
    <% } %>
</div>
<% } %>
<% if(error && error.length > 0){ %>
<div class="flash-container" id="flashContainer">
    <% for(let msg of error){ %>
    <div class="flash-message error">
        <i class="fas fa-exclamation-circle flash-icon"></i>
        <span><%= msg %></span>
        <button onclick="this.parentElement.remove()" style="margin-left:auto; background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:1rem; padding:0 0 0 8px;">&times;</button>
    </div>
    <% } %>
</div>
<% } %>
<script>
setTimeout(function() {
    var fc = document.getElementById('flashContainer');
    if(fc) fc.style.opacity = '0', fc.style.transition = 'opacity 0.5s', setTimeout(function(){ if(fc) fc.remove(); }, 500);
}, 4000);
</script>
